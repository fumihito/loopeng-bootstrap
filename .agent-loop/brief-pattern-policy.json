{
  "version": 1,
  "enabled": true,
  "directory": "loop-brief-patterns",
  "okf_type": "Loop Brief Pattern",
  "require_explicit_user_confirmation": true,
  "require_gatekeeper_acceptance": true,
  "require_brief_pattern_curator": true,
  "capture_complete_briefs": true,
  "max_candidates": 8,
  "max_proposals_per_brief": 2,
  "match_keys": [
    "task_class",
    "repository_kind",
    "risk_class",
    "trigger_kind"
  ],
  "never_silent_fields": [
    "authority_envelope",
    "memory_contract",
    "stop_conditions",
    "escalation_contract",
    "trigger_cadence"
  ],
  "task_specific_fields": [
    "outcome",
    "discovery_scope"
  ],
  "candidate_default_fields": [
    "evaluation_contract",
    "persistence_contract",
    "learning_contract"
  ],
  "allowed_reuse_policies": [
    "confirm",
    "suggest-only",
    "disabled"
  ],
  "default_reuse_policy": "confirm",
  "default_sensitivity": "internal"
}
