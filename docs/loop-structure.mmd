flowchart TD
    classDef det fill:#eef4ff,stroke:#345c9c,stroke-width:1.4px,color:#10233e;
    classDef llm fill:#fff7df,stroke:#b57a00,stroke-width:1.4px,color:#3d2600;
    classDef human fill:#fdeef4,stroke:#b04f74,stroke-width:1.4px,color:#4a1028;

    HUMAN[Human]:::human

    subgraph ENTRY["入口ルーティング (ターン開始)"]
        direction TD
        UP[UserPromptSubmit]:::human
        ROUTER{strict leading prefix precedence<br/>direct: → frame-* → route: → &lt;header&gt; → Gatekeeper}:::det
        DIRECT[DIRECT<br/>bounded / Gatekeeper-free<br/>read-only by default]:::det
        FRAME[FRAME<br/>isolated frame skill]:::det
        COMMAND_ROUTE[COMMAND_ROUTE<br/>frame shortlist proposal<br/>stays outside loop]:::det
        SOP[SOP<br/>isolated sop-&lt;header&gt; skill]:::det
    end

    subgraph LOOP["ループ本体 (1ターン内部)"]
        direction TD
        GK{gatekeeper<br/>READY / NEEDS_INPUT / REJECT}:::llm
        LBA[loop-brief-assistant<br/>clarify missing conditions]:::llm
        BP[brief-pattern-curator<br/>commit accepted patterns]:::llm
        SM[sensemaker<br/>progressive OKF LLMWiki retrieval]:::llm
        GOV[governor<br/>policy / authority enforcement]:::llm
        INT[integrator<br/>compose parallel outputs]:::llm
        VALIDATE[deterministic validation<br/>allowlist]:::det
        ST[state-steward<br/>record state + memory proposals]:::llm
        ME{meta-evaluator<br/>PASS / REVISE / ESCALATE}:::llm
        MC[memory-curator<br/>okfctl transaction]:::llm
        WIKI[(LLMWiki)]:::det
        OBS[Learning Observer]:::det
        LA[learning-auditor<br/>sop-learning-audit]:::llm
        RECOVERY[watchdog-recovery<br/>continue / rollback / escalate]:::llm
    end

    subgraph HOOK["決定論的境界 (hook)"]
        direction TD
        SANITIZE[hook sanitize<br/>journal / telemetry]:::det
        MUTATE_GATE[mutation gate<br/>protected-path / permission]:::det
        DRIFT_GUARD[protected-path drift]:::det
        WATCHDOG_GATE[watchdog gate<br/>tool / failure budget]:::det
        OKFCTL[okfctl transaction]:::det
    end

    subgraph SCHED["スケジューラ (ターン間)"]
        direction TD
        PASS[PASS]:::det
        REVISE[REVISE]:::det
        ESC[ESCALATE]:::det
        GEX[GATE_EXHAUSTED]:::det
        WTR[WATCHDOG_TRIPPED]:::det
        PDR[PROTECTED_DRIFT]:::det
        NEXT[next-turn.json<br/>gatekeeper-prompt.txt<br/>gatekeeper-prompt.json]:::det
        CAD{daemon cadence gate<br/>immediate / manual / on-event / unknown}:::det
        LEGEND[Legend<br/>det = hook / daemon / okfctl<br/>llm = ROLES-derived role<br/>human = human<br/>loop = autonomous loop]:::det
    end

    UP --> ROUTER
    ROUTER -->|direct:| DIRECT
    ROUTER -->|frame-<name>:| FRAME
    ROUTER -->|route:| COMMAND_ROUTE
    ROUTER -->|other strict leading &lt;header&gt;:| SOP
    ROUTER -->|no prefix| GK

    DIRECT --> HUMAN
    FRAME --> HUMAN
    COMMAND_ROUTE -->|selected frame| FRAME
    COMMAND_ROUTE -->|needs_user_turn| HUMAN
    SOP -->|learning-audit:| LA
    SOP -->|other sop-&lt;header&gt;| HUMAN

    HUMAN -.->|"continuation ≤ max_stop_continuations"| GK
    HUMAN -->|"continuation > max_stop_continuations"| GEX

    GK -->|NEEDS_INPUT| LBA
    GK -->|READY + PATTERN_CAPTURE| BP
    GK -->|READY| SM
    GK -->|REJECT| ESC

    LBA -->|questions_to_user| HUMAN
    BP -.->|"continuation ≤ max_stop_continuations"| GK

    SM -.->|selected prior knowledge| WIKI
    WIKI -.->|selected prior knowledge| SM
    SM --> GOV
    GOV --> MUTATE_GATE
    GOV -->|denied| ESC
    MUTATE_GATE --> INT
    MUTATE_GATE -.->|protected-path drift| DRIFT_GUARD
    DRIFT_GUARD --> PDR

    INT --> VALIDATE
    INT -.->|tool events / failure budget| WATCHDOG_GATE
    VALIDATE --> ST
    VALIDATE -.->|tool events / failure budget| WATCHDOG_GATE
    WATCHDOG_GATE --> RECOVERY

    ST -.->|sanitized journal / telemetry| SANITIZE
    ME -.->|sanitized journal / telemetry| SANITIZE
    MC -.->|sanitized journal / telemetry| SANITIZE
    LA -.->|sanitized journal / telemetry| SANITIZE
    GK -.->|sanitized journal / telemetry| SANITIZE

    ST --> ME
    ME -->|PASS| PASS
    ME -->|REVISE| REVISE
    ME -->|ESCALATE| ESC

    PASS -->|accepted memory proposals| MC
    PASS -->|no durable memory| OBS
    MC --> OKFCTL
    OKFCTL --> WIKI
    OKFCTL --> OBS

    RECOVERY -->|continue with changed approach| REVISE
    RECOVERY -->|rollback| ESC
    RECOVERY -->|escalate| ESC
    RECOVERY --> WTR

    REVISE -.->|"continuation ≤ max_stop_continuations"| INT

    OBS -.->|learning-audit:| LA
    LA --> NEXT
    OBS --> NEXT

    PASS --> NEXT
    REVISE --> NEXT
    ESC --> NEXT
    GEX --> NEXT
    WTR --> NEXT
    PDR --> NEXT

    NEXT -->|ready_for_next_turn = true| CAD
    NEXT -->|ready_for_next_turn = false<br/>notification_command| HUMAN
    CAD -->|immediate| UP
    CAD -->|manual / on-event / unknown<br/>skip| HUMAN

    LEGEND -.->|legend sample| DIRECT
    LEGEND -.->|legend sample| GK
    LEGEND -.->|legend sample| HUMAN
