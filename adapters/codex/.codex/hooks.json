{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Loading loop protocol"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Governor policy check"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|Edit|Write|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Checking approval policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Recording loop state"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "gatekeeper|sensemaker|governor|state-steward|watchdog-recovery|meta-evaluator|learning-auditor|memory-curator",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Checking completion gates"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "gatekeeper|sensemaker|governor|state-steward|watchdog-recovery|meta-evaluator|learning-auditor|memory-curator",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.agent-loop/hooks/loop_hook.py\" --platform codex",
            "timeout": 30,
            "statusMessage": "Recording role activation"
          }
        ]
      }
    ]
  }
}
