{
  "hooks": {
    "SessionStart": [{"matcher": "startup|resume|clear|compact", "hooks": [{"type": "command", "command": "python3 -m loopeng hook codex", "timeout": 30, "statusMessage": "Loading loop protocol"}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "python3 -m loopeng hook codex", "timeout": 30}]}],
    "PreToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "python3 -m loopeng hook codex", "timeout": 30, "statusMessage": "Governor policy check"}]}],
    "PostToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "python3 -m loopeng hook codex", "timeout": 30, "statusMessage": "Recording loop state"}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "python3 -m loopeng hook codex", "timeout": 60, "statusMessage": "Writing Run Report"}]}]
  }
}
